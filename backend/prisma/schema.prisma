generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MODERATOR
  MENTOR
  PARTICIPANT
}

enum ProjectStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  ACCEPTED
  REJECTED
}

enum HackathonStatus {
  UPCOMING
  REGISTRATION_OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Country {
  id        String   @id @default(uuid())
  name      String   @unique
  code      String   @unique @db.VarChar(3)
  flagEmoji String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  users     User[]
  projects  Project[]
  hackathons Hackathon[]
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  role      Role     @default(PARTICIPANT)
  age       Int?
  phone     String?
  bio       String?
  active    Boolean  @default(true)
  countryId String?
  country   Country? @relation(fields: [countryId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  projects  Project[]
  teamMemberships TeamMember[]
  news      News[]
}

model Project {
  id          String        @id @default(uuid())
  title       String
  description String
  heritage    String?
  status      ProjectStatus @default(DRAFT)
  authorId    String
  author      User          @relation(fields: [authorId], references: [id])
  countryId   String?
  country     Country?      @relation(fields: [countryId], references: [id])
  team        Team?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Team {
  id        String       @id @default(uuid())
  name      String
  projectId String       @unique
  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  members   TeamMember[]
  createdAt DateTime     @default(now())
}

model TeamMember {
  id        String   @id @default(uuid())
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  role      String   @default("member")
  createdAt DateTime @default(now())

  @@unique([teamId, userId])
}

model Hackathon {
  id          String          @id @default(uuid())
  title       String
  description String
  startDate   DateTime
  endDate     DateTime
  maxTeams    Int             @default(10)
  quotaPerCountry Int         @default(5)
  status      HackathonStatus @default(UPCOMING)
  countryId   String?
  country     Country?        @relation(fields: [countryId], references: [id])
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model Course {
  id          String   @id @default(uuid())
  title       String
  description String
  moduleOrder Int      @default(0)
  duration    Int?
  content     String?
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model News {
  id          String   @id @default(uuid())
  title       String
  content     String
  published   Boolean  @default(false)
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
