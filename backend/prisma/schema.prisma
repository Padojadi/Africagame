generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  EXPLOITANT
  REGULATEUR
  OPERATEUR
}

enum Channel {
  RETAIL
  ONLINE
  USSD
  SMS
}

enum PaymentNature {
  DEPOT
  RETRAIT
}

enum PaymentStatus {
  PENDING
  SUCCESS
  ERROR
  EXPIRED
  OUTSIDE_CONCENTRATOR
}

enum BetNature {
  PRISE_PARI
  PAIEMENT
  ANNULATION
  CASHOUT
}

enum BetStatus {
  PENDING
  WON
  LOST
  CASHOUT
  EXPIRED
  CANCELLED
}

enum GameType {
  SPORT
  HIPPIQUE
  VIRTUEL
  CASINO
  LOTO
  OTHER
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  VALIDATE
  REJECT
  EXPORT
  CONFIGURE
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Currency {
  id        String   @id @default(uuid())
  code      String   @unique @db.VarChar(5)
  name      String
  symbol    String
  decimals  Int      @default(2)
  active    Boolean  @default(true)
  jurisdictions Jurisdiction[]
}

model Jurisdiction {
  id              String   @id @default(uuid())
  name            String
  code            String   @unique @db.VarChar(5)
  currencyId      String
  currency        Currency @relation(fields: [currencyId], references: [id])
  timezone        String   @default("Africa/Abidjan")
  defaultLanguage String   @default("fr")
  active          Boolean  @default(true)
  dataRetentionMonths Int  @default(18)
  archiveYears    Int      @default(5)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  users           User[]
  gameOperators   GameOperator[]
  paymentProviders PaymentProvider[]
  regulatoryRules RegulatoryRule[]
  payments        PaymentTransaction[]
  bets            BetTransaction[]
  invoices        Invoice[]
  allowedChannels JurisdictionChannel[]
}

model JurisdictionChannel {
  id             String       @id @default(uuid())
  jurisdictionId String
  jurisdiction   Jurisdiction @relation(fields: [jurisdictionId], references: [id], onDelete: Cascade)
  channel        Channel
  enabled        Boolean      @default(true)

  @@unique([jurisdictionId, channel])
}

model User {
  id             String        @id @default(uuid())
  email          String        @unique
  password       String
  firstName      String
  lastName       String
  role           UserRole
  active         Boolean       @default(true)
  mfaEnabled     Boolean       @default(false)
  jurisdictionId String?
  jurisdiction   Jurisdiction? @relation(fields: [jurisdictionId], references: [id])
  gameOperatorId String?
  gameOperator   GameOperator? @relation(fields: [gameOperatorId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  auditLogs      AuditLog[]
}

model GameOperator {
  id             String       @id @default(uuid())
  name           String
  licenseNumber  String
  apiKey         String       @unique @default(uuid())
  active         Boolean      @default(true)
  jurisdictionId String
  jurisdiction   Jurisdiction @relation(fields: [jurisdictionId], references: [id])
  users          User[]
  payments       PaymentTransaction[]
  bets           BetTransaction[]
  invoices       Invoice[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([jurisdictionId, licenseNumber])
}

model PaymentProvider {
  id             String       @id @default(uuid())
  name           String
  code           String
  type           String       @default("MOBILE_MONEY")
  jurisdictionId String
  jurisdiction   Jurisdiction @relation(fields: [jurisdictionId], references: [id])
  config         Json?
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())

  @@unique([jurisdictionId, code])
}

model RegulatoryRule {
  id             String       @id @default(uuid())
  jurisdictionId String
  jurisdiction   Jurisdiction @relation(fields: [jurisdictionId], references: [id])
  name           String
  baseType       String       @default("PBJ")
  rate           Decimal      @db.Decimal(8, 4)
  threshold      Decimal?     @db.Decimal(18, 2)
  periodicity    String       @default("MONTHLY")
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model PaymentTransaction {
  id               String        @id @default(uuid())
  externalId       String?
  idempotencyKey   String?       @unique
  jurisdictionId   String
  jurisdiction     Jurisdiction  @relation(fields: [jurisdictionId], references: [id])
  gameOperatorId   String
  gameOperator     GameOperator  @relation(fields: [gameOperatorId], references: [id])
  nature           PaymentNature
  amount           Decimal       @db.Decimal(18, 2)
  currencyCode     String
  channel          Channel
  msisdn           String?
  sessionId        String?
  actorRef         String?
  status           PaymentStatus @default(PENDING)
  outsideConcentrator Boolean    @default(false)
  operatedAt       DateTime      @default(now())
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  steps            PaymentStep[]

  @@index([jurisdictionId, operatedAt])
  @@index([gameOperatorId, operatedAt])
  @@index([msisdn])
  @@index([channel])
}

model PaymentStep {
  id            String             @id @default(uuid())
  paymentId     String
  payment       PaymentTransaction @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  stepOrder     Int
  stepType      String
  status        PaymentStatus
  payload       Json?
  createdAt     DateTime           @default(now())
}

model BetTransaction {
  id             String       @id @default(uuid())
  externalId     String?
  idempotencyKey String?      @unique
  jurisdictionId String
  jurisdiction   Jurisdiction @relation(fields: [jurisdictionId], references: [id])
  gameOperatorId String
  gameOperator   GameOperator @relation(fields: [gameOperatorId], references: [id])
  nature         BetNature
  amount         Decimal      @db.Decimal(18, 2)
  currencyCode   String
  channel        Channel
  msisdn         String?
  gameType       GameType
  actorRef       String?
  status         BetStatus    @default(PENDING)
  undeclared     Boolean      @default(false)
  operatedAt     DateTime     @default(now())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([jurisdictionId, operatedAt])
  @@index([gameOperatorId, operatedAt])
  @@index([msisdn])
  @@index([channel])
}

model Invoice {
  id             String       @id @default(uuid())
  jurisdictionId String
  jurisdiction   Jurisdiction @relation(fields: [jurisdictionId], references: [id])
  gameOperatorId String
  gameOperator   GameOperator @relation(fields: [gameOperatorId], references: [id])
  periodStart    DateTime
  periodEnd      DateTime
  pbjAmount      Decimal      @db.Decimal(18, 2)
  levyAmount     Decimal      @db.Decimal(18, 2)
  currencyCode   String
  status         String       @default("DRAFT")
  createdAt      DateTime     @default(now())
}

model ResponsibleGamingProfile {
  id             String    @id @default(uuid())
  msisdn         String?
  playerRef      String?
  jurisdictionId String
  riskLevel      RiskLevel @default(LOW)
  totalDeposits  Decimal   @default(0) @db.Decimal(18, 2)
  totalBets      Decimal   @default(0) @db.Decimal(18, 2)
  notes          String?
  updatedAt      DateTime  @updatedAt
  createdAt      DateTime  @default(now())

  @@index([msisdn])
  @@index([jurisdictionId, riskLevel])
}

model AuditLog {
  id        String      @id @default(uuid())
  userId    String?
  user      User?       @relation(fields: [userId], references: [id])
  action    AuditAction
  entity    String
  entityId  String?
  details   Json?
  ipAddress String?
  createdAt DateTime    @default(now())

  @@index([createdAt])
  @@index([userId])
  @@index([entity, entityId])
}

model UssdSession {
  id             String   @id @default(uuid())
  sessionId      String   @unique
  msisdn         String
  jurisdictionId String
  gameOperatorId String?
  channel        Channel  @default(USSD)
  currentStep    String?
  status         String   @default("ACTIVE")
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([msisdn])
  @@index([expiresAt])
}

model SmsMessage {
  id             String   @id @default(uuid())
  messageId      String   @unique
  msisdn         String
  jurisdictionId String
  direction      String
  keyword        String?
  body           String
  dlrStatus      String?
  correlatedId   String?
  processed      Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([msisdn])
  @@index([messageId])
}
